MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 70c970a7d9f7d414994564bd048e8a6d, type: 3}
  m_Name: UFO_Questionable_Distance
  m_EditorClassIdentifier: KBTV.Runtime::KBTV.Dialogue.CallerDialogueTemplate
  Topic: {fileID: 0}
  Legitimacy: 1
  Priority: 2
  Length: 8
  IntroLines:
  - Text: I was driving on the highway last week and I saw lights in the distance
      that didn't make sense.
    Tone: 10
    Weight: 1
  - Text: Vern, I'm a delivery driver. I'm on the road all night. Last Tuesday I
      saw something over the fields.
    Tone: 0
    Weight: 1
  - Text: So I was out on Route 9, middle of nowhere, and there were these lights
      on the horizon doing impossible things.
    Tone: 10
    Weight: 1
  DetailLines:
  - Text: Three lights in a row, just hovering. Then they shot off in different directions
      simultaneously. Like, instant.
    Tone: 0
    Weight: 1
  - Text: I pulled over to watch. They were maybe a mile out? Hard to tell at night.
      Moving in formation, then splitting up.
    Tone: 8
    Weight: 1
  - Text: It was too far to get a good video. Just looks like dots on my phone. But
      I know what I saw.
    Tone: 10
    Weight: 1
  DefenseLines:
  - Text: No airport out there, Vern. I've driven that route a hundred times. Never
      seen planes do that.
    Tone: 0
    Weight: 1
  - Text: Drones? Maybe. But they were big. And fast. Military drones? I don't know.
    Tone: 8
    Weight: 1
  - Text: I'm not saying it was aliens. But it wasn't normal aircraft. I'd stake
      my job on it.
    Tone: 10
    Weight: 1
  AcceptanceLines:
  - Text: Yeah, that's what I figured too. Just needed someone else to say it.
    Tone: 0
    Weight: 1
  - Text: Okay, good. I'm not crazy then. That's a relief.
    Tone: 10
    Weight: 1
  - Text: I might keep a better camera in the truck from now on. Just in case.
    Tone: 0
    Weight: 1
  ExtraDetailLines: []
  ExtraDefenseLines: []
  ConclusionLines:
  - Text: Thanks Vern. I'll keep my eyes on the sky during my routes.
    Tone: 0
    Weight: 1
  - Text: If I see it again, I'll call back. Got your number on speed dial now.
    Tone: 10
    Weight: 1
  - Text: Appreciate you taking the call. Stay safe out there.
    Tone: 0
    Weight: 1
