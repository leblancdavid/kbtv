  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 70c970a7d9f7d414994564bd048e8a6d, type: 3}
  m_Name: UFO_Questionable_Sleepy
  m_EditorClassIdentifier: KBTV.Runtime::KBTV.Dialogue.CallerDialogueTemplate
  Topic: {fileID: 0}
  Legitimacy: 1
  Priority: 2
  Length: 8
  IntroLines:
  - Text: Vern, I was up at like 3 AM and I saw something outside my window. Couldn't
      sleep after.
    Tone: 10
    Weight: 1
  - Text: I know this sounds crazy, but I woke up in the middle of the night and
      there was this light hovering outside.
    Tone: 10
    Weight: 1
  - Text: Okay so I might have been half asleep, but I swear I saw something in the
      sky last night.
    Tone: 8
    Weight: 1
  DetailLines:
  - Text: It was this soft, pulsing light. Just hanging there above the treeline.
      I watched it for... I don't know, felt like forever.
    Tone: 8
    Weight: 1
  - Text: I rubbed my eyes, Vern. Multiple times. It was still there. Orange-ish,
      maybe yellow. Moving slow.
    Tone: 10
    Weight: 1
  - Text: No sound. That's what got me. At 3 AM everything is quiet and this thing
      made zero noise.
    Tone: 10
    Weight: 1
  DefenseLines:
  - Text: I wasn't dreaming. I got up, I got water, I looked again. Still there.
    Tone: 10
    Weight: 1
  - Text: Yeah, I was tired. But I know the difference between a dream and reality.
      Mostly.
    Tone: 8
    Weight: 1
  - Text: My dog was barking at the window too. Dogs don't bark at dreams, do they?
    Tone: 10
    Weight: 1
  AcceptanceLines:
  - Text: Thank god. I thought I was losing it. Haven't slept right since.
    Tone: 10
    Weight: 1
  - Text: That's what I needed to hear. Maybe I'm not crazy after all.
    Tone: 0
    Weight: 1
  - Text: Right, right. That makes me feel better.
    Tone: 8
    Weight: 1
  ExtraDetailLines: []
  ExtraDefenseLines: []
  ConclusionLines:
  - Text: Thanks Vern. I just needed to tell someone who wouldn't laugh.
    Tone: 10
    Weight: 1
  - Text: I'm gonna try to sleep tonight. Maybe with the curtains closed.
    Tone: 10
    Weight: 1
  - Text: Okay, I feel better. Thanks for listening.
    Tone: 0
    Weight: 1
