MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 70c970a7d9f7d414994564bd048e8a6d, type: 3}
  m_Name: UFO_Fake_Vague
  m_EditorClassIdentifier: KBTV.Runtime::KBTV.Dialogue.CallerDialogueTemplate
  Topic: {fileID: 0}
  Legitimacy: 0
  Priority: 2
  Length: 6
  IntroLines:
  - Text: Uh, hi Vern. I think I maybe saw something? In the sky?
    Tone: 10
    Weight: 1
  - Text: So like, I don't know if this counts, but there was this... thing.
    Tone: 8
    Weight: 1
  - Text: First time caller. Long time listener. I saw a UFO. I think. Maybe.
    Tone: 10
    Weight: 1
  DetailLines:
  - Text: It was... a light? Or maybe two lights. Could've been one. It was moving.
      Or hovering. One of those.
    Tone: 8
    Weight: 1
  - Text: I don't really remember where exactly. Outside somewhere. At night. Or
      evening. Definitely dark-ish.
    Tone: 10
    Weight: 1
  - Text: The size? Um. Big? Medium? It was far away. Or close. Hard to tell with
      perspective and stuff.
    Tone: 8
    Weight: 1
  DefenseLines:
  - Text: I mean, it could have been a plane. But it felt different. In my gut. You
      know?
    Tone: 10
    Weight: 1
  - Text: Look, I know I'm not great with details, but something was there. Probably.
    Tone: 10
    Weight: 1
  - Text: My sister saw it too but she says it was a helicopter. But she's wrong.
      I think.
    Tone: 8
    Weight: 1
  AcceptanceLines:
  - Text: Oh, okay. Yeah. That makes sense.
    Tone: 10
    Weight: 1
  - Text: Right, that's what I thought. Probably. Maybe.
    Tone: 8
    Weight: 1
  - Text: Uh huh. Yeah. Sure.
    Tone: 8
    Weight: 1
  ExtraDetailLines: []
  ExtraDefenseLines: []
  ConclusionLines:
  - Text: Okay, thanks Vern. Sorry I couldn't be more specific.
    Tone: 10
    Weight: 1
  - Text: I'll call back if I remember more details. If I do. Which I might not.
    Tone: 8
    Weight: 1
  - Text: Bye. Love the show. Mostly.
    Tone: 10
    Weight: 1
